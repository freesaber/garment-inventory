<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.inventory.mapper.GiStocktakeMapper">
    
    <resultMap type="GiStocktake" id="GiStocktakeResult">
        <id     property="stocktakeId"  column="stocktake_id"  />
        <result property="stocktakeNo"  column="stocktake_no"  />
        <result property="deptId"       column="dept_id"       />
        <result property="deptName"     column="dept_name"     />
        <result property="itemCount"    column="item_count"    />
        <result property="diffAmount"   column="diff_amount"   />
        <result property="status"       column="status"        />
        <result property="auditBy"      column="audit_by"      />
        <result property="auditTime"    column="audit_time"    />
        <result property="remark"       column="remark"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateTime"   column="update_time"   />
    </resultMap>

    <sql id="selectGiStocktakeVo">
        select s.stocktake_id, s.stocktake_no, s.dept_id, d.dept_name, s.item_count, s.diff_amount,
               s.status, s.audit_by, s.audit_time, s.remark, s.create_by, s.create_time, s.update_time
        from gi_stocktake s
        left join sys_dept d on s.dept_id = d.dept_id
    </sql>

    <select id="selectGiStocktakeList" parameterType="GiStocktake" resultMap="GiStocktakeResult">
        <include refid="selectGiStocktakeVo"/>
        <where>
            <if test="stocktakeNo != null and stocktakeNo != ''">
                AND s.stocktake_no like concat('%', #{stocktakeNo}, '%')
            </if>
            <if test="deptId != null">
                AND s.dept_id = #{deptId}
            </if>
            <if test="status != null and status != ''">
                AND s.status = #{status}
            </if>
        </where>
        order by s.create_time desc
    </select>

    <select id="selectGiStocktakeById" parameterType="Long" resultMap="GiStocktakeResult">
        <include refid="selectGiStocktakeVo"/>
        where s.stocktake_id = #{stocktakeId}
    </select>

    <select id="generateStocktakeNo" resultType="String">
        select concat('PD', date_format(now(), '%Y%m%d'), lpad(ifnull(max(right(stocktake_no, 4)), 0) + 1, 4, '0'))
        from gi_stocktake
        where stocktake_no like concat('PD', date_format(now(), '%Y%m%d'), '%')
    </select>

    <insert id="insertGiStocktake" parameterType="GiStocktake" useGeneratedKeys="true" keyProperty="stocktakeId">
        insert into gi_stocktake
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="stocktakeNo != null">stocktake_no,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="itemCount != null">item_count,</if>
            <if test="diffAmount != null">diff_amount,</if>
            <if test="status != null">status,</if>
            <if test="auditBy != null">audit_by,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="stocktakeNo != null">#{stocktakeNo},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="itemCount != null">#{itemCount},</if>
            <if test="diffAmount != null">#{diffAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="auditBy != null">#{auditBy},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateGiStocktake" parameterType="GiStocktake">
        update gi_stocktake
        <trim prefix="SET" suffixOverrides=",">
            <if test="itemCount != null">item_count = #{itemCount},</if>
            <if test="diffAmount != null">diff_amount = #{diffAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            update_time = sysdate()
        </trim>
        where stocktake_id = #{stocktakeId}
    </update>

    <delete id="deleteGiStocktakeByIds" parameterType="Long">
        delete from gi_stocktake where stocktake_id in
        <foreach item="stocktakeId" collection="array" open="(" separator="," close=")">
            #{stocktakeId}
        </foreach>
    </delete>
</mapper>
