<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.inventory.mapper.GiTransferItemMapper">
    
    <resultMap type="GiTransferItem" id="GiTransferItemResult">
        <id     property="itemId"     column="item_id"     />
        <result property="transferId" column="transfer_id" />
        <result property="skuId"      column="sku_id"      />
        <result property="skuCode"    column="sku_code"    />
        <result property="goodsName"  column="goods_name"  />
        <result property="color"      column="color"       />
        <result property="size"       column="size"        />
        <result property="quantity"   column="quantity"    />
        <result property="outQty"     column="out_qty"     />
        <result property="inQty"      column="in_qty"      />
    </resultMap>

    <select id="selectByTransferId" parameterType="Long" resultMap="GiTransferItemResult">
        select item_id, transfer_id, sku_id, sku_code, goods_name, color, size, quantity, out_qty, in_qty
        from gi_transfer_item
        where transfer_id = #{transferId}
    </select>

    <insert id="insertBatch" parameterType="java.util.List">
        insert into gi_transfer_item (transfer_id, sku_id, sku_code, goods_name, color, size, quantity, out_qty, in_qty) values
        <foreach collection="list" item="item" separator=",">
            (#{item.transferId}, #{item.skuId}, #{item.skuCode}, #{item.goodsName}, #{item.color}, #{item.size}, #{item.quantity}, 0, 0)
        </foreach>
    </insert>

    <delete id="deleteByTransferId" parameterType="Long">
        delete from gi_transfer_item where transfer_id = #{transferId}
    </delete>
</mapper>
