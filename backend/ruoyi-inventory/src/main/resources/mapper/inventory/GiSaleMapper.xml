<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.inventory.mapper.GiSaleMapper">
    
    <resultMap type="GiSale" id="GiSaleResult">
        <id     property="saleId"         column="sale_id"         />
        <result property="saleNo"         column="sale_no"         />
        <result property="deptId"         column="dept_id"         />
        <result property="deptName"       column="dept_name"       />
        <result property="totalAmount"    column="total_amount"    />
        <result property="payAmount"      column="pay_amount"      />
        <result property="discountAmount" column="discount_amount" />
        <result property="payType"        column="pay_type"        />
        <result property="status"         column="status"          />
        <result property="remark"         column="remark"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
    </resultMap>

    <sql id="selectGiSaleVo">
        select s.sale_id, s.sale_no, s.dept_id, d.dept_name, s.total_amount, s.pay_amount, 
               s.discount_amount, s.pay_type, s.status, s.remark, s.create_by, s.create_time
        from gi_sale s
        left join sys_dept d on s.dept_id = d.dept_id
    </sql>

    <select id="selectGiSaleList" parameterType="GiSale" resultMap="GiSaleResult">
        <include refid="selectGiSaleVo"/>
        <where>
            <if test="saleNo != null and saleNo != ''">
                AND s.sale_no like concat('%', #{saleNo}, '%')
            </if>
            <if test="deptId != null">
                AND s.dept_id = #{deptId}
            </if>
            <if test="payType != null and payType != ''">
                AND s.pay_type = #{payType}
            </if>
            <if test="status != null and status != ''">
                AND s.status = #{status}
            </if>
        </where>
        order by s.create_time desc
    </select>

    <select id="selectGiSaleById" parameterType="Long" resultMap="GiSaleResult">
        <include refid="selectGiSaleVo"/>
        where s.sale_id = #{saleId}
    </select>

    <select id="generateSaleNo" resultType="String">
        select concat('S', date_format(now(), '%Y%m%d'), lpad(ifnull(max(right(sale_no, 4)), 0) + 1, 4, '0'))
        from gi_sale
        where sale_no like concat('S', date_format(now(), '%Y%m%d'), '%')
    </select>

    <insert id="insertGiSale" parameterType="GiSale" useGeneratedKeys="true" keyProperty="saleId">
        insert into gi_sale
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="saleNo != null">sale_no,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="payAmount != null">pay_amount,</if>
            <if test="discountAmount != null">discount_amount,</if>
            <if test="payType != null">pay_type,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="saleNo != null">#{saleNo},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="payAmount != null">#{payAmount},</if>
            <if test="discountAmount != null">#{discountAmount},</if>
            <if test="payType != null">#{payType},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateGiSale" parameterType="GiSale">
        update gi_sale
        <trim prefix="SET" suffixOverrides=",">
            <if test="payType != null">pay_type = #{payType},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where sale_id = #{saleId}
    </update>

    <delete id="deleteGiSaleById" parameterType="Long">
        delete from gi_sale where sale_id = #{saleId}
    </delete>

    <delete id="deleteGiSaleByIds" parameterType="String">
        delete from gi_sale where sale_id in
        <foreach item="saleId" collection="array" open="(" separator="," close=")">
            #{saleId}
        </foreach>
    </delete>
</mapper>
